# CoinGecko API Configuration
# Get your API key from: https://www.coingecko.com/en/api
CG_API_KEY=your_coingecko_api_key_here

# Alpaca Trading API Configuration
# Get your credentials from: https://alpaca.markets/
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Alpaca Base URL - use paper trading URL for testing
# Paper trading: https://paper-api.alpaca.markets
# Live trading: https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets
